# Python
__pycache__/
*.py[cod]
*.pyo
.env
venv/
.venv/
env/
.pytest_cache/
*.egg-info/
dist/
build/
.eggs/
*.egg

# Scraper log — can grow large and is not source code
scraper.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Data files — large binaries and text; only the index CSV is tracked
data/pages/*
!data/pages/.gitkeep
data/transcript/*
!data/transcript/.gitkeep

# Quarantined outlier pages (covers/blanks/repeats) moved out of the dataset
data/outliers/

# Models — large binary files; only the folder structure is tracked
models/*
!models/.gitkeep

# Segmentation test — keep the runner script and text summaries, ignore the
# per-page line-crop PNGs (regenerable binary output)
segmentation_test/page_*/
